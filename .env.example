# PitchPal configuration. Copy to .env and fill in values.
# The app runs fully offline (grounded fallback engine) if no LLM key is set.

# Server
PORT=3000
NODE_ENV=development

# CORS: comma-separated list of allowed origins. Use * only for local dev.
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# --- Optional GenAI LLM provider (OpenAI-compatible Chat Completions API) ---
# When LLM_API_KEY is present the assistant uses the live model with RAG grounding.
# When absent, PitchPal uses its built-in grounded reasoning engine.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=15000
